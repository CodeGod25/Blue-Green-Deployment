# Project Titanium Environment Configuration
# Copy this to .env to customize your local setup

# The main web entry point (default: 80)
# Change this if port 80 is already in use by another application
# Example: HTTP_PORT=8080
HTTP_PORT=80

# The monitor control plane API (default: 8090)
MONITOR_PORT=8090

# Docker Socket (usually /var/run/docker.sock on Unix/Mac/WSL)
DOCKER_SOCKET=/var/run/docker.sock
